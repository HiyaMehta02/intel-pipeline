# Copy to .env and adjust for local development.

# Runtime profile: local | staging | prod
ENVIRONMENT=local

# Writable root for raw artifacts, briefings, and SQLite (created on first run)
DATA_DIR=./data

# SQLAlchemy URL (SQLite local; Postgres in staging/prod — Sprint 4)
DATABASE_URL=sqlite:///./data/pipeline.db

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Near-duplicate detection (disabled for Sprint 1)
ENABLE_NEAR_DEDUP=false
